{
    "version": 2,
    "configurePresets": [
        {
            "name": "vcpkg-debug",
            "displayName": "ninja-debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "vcpkg-release",
            "displayName": "ninja-release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "vcpkg-gcc15-debug",
            "displayName": "ninja-debug (gcc-15)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/gcc15-debug",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "gcc-15",
                "CMAKE_CXX_COMPILER": "g++-15"
            }
        },
        {
            "name": "vcpkg-clang-debug",
            "displayName": "ninja-debug (clang-22)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/clang-debug",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "vcpkg-msvc-debug",
            "displayName": "ninja-debug (msvc x64)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/msvc-debug",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            }
        },
        {
            "name": "vcpkg-msvc-release",
            "displayName": "ninja-release (msvc x64)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/msvc-release",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "vcpkg-debug",
            "configurePreset": "vcpkg-debug",
            "jobs": 12
        },
        {
            "name": "vcpkg-release",
            "configurePreset": "vcpkg-release",
            "jobs": 12
        }
    ],
    "testPresets": [
        {
            "name": "vcpkg-debug",
            "configurePreset": "vcpkg-debug"
        },
        {
            "name": "vcpkg-release",
            "configurePreset": "vcpkg-release"
        }
    ]
}